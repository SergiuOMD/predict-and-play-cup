# Supabase (client — expuse în browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Supabase (server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_PROJECT_ID=your-project-id

# football-data.org — doar server-side, nu expune în client
FOOTBALL_DATA_API_TOKEN=your-football-data-api-token

# Secret pentru cron (Edge Function sync-match-scores + server fn)
CRON_SECRET=generate-a-long-random-secret

# Supabase service role — necesar pentru sync auto scoruri (server)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
